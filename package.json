{
  "name": "clawdemy",
  "description": "Free AI literacy for everyday users. Sister project to Clawless Computer.",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/clawless-io/clawdemy.git"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && pagefind --site dist --output-path dist/pagefind",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "validate:content": "bun run scripts/validate-content.ts",
    "validate:attribution": "bun run scripts/validate-attribution.ts",
    "validate:all": "bun run validate:content && bun run validate:attribution"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.38.3",
    "@astrojs/starlight-tailwind": "^4.0.1",
    "@tailwindcss/vite": "^4.1.0",
    "astro": "^6.0.1",
    "pagefind": "^1.4.0",
    "sharp": "^0.34.2",
    "tailwindcss": "^4.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@types/bun": "^1.3.0",
    "gray-matter": "^4.0.3",
    "typescript": "^5.7.0",
    "zod": "^3.24.0"
  }
}
