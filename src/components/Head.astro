---
/**
 * Head override for Starlight.
 *
 * Starlight 0.38 already emits og:title, og:type, og:url, og:locale,
 * og:description, og:site_name, and twitter:card automatically from page
 * frontmatter. We add og:image and twitter:image (which Starlight does NOT
 * emit by default) so social-share previews render with a branded card
 * instead of plain text.
 *
 * Default OG image: /og-default.png (1200x630). Generated by
 * scripts/generate-og-image.ts. Replace with a designed asset whenever ready;
 * no code change needed here.
 *
 * Per-page OG image override is a future enhancement: when individual lessons
 * want their own preview card, we'll add an `og_image` frontmatter field and
 * conditionally use it here.
 */

import Default from '@astrojs/starlight/components/Head.astro';

const ogImage = new URL('/og-default.png', Astro.site).toString();
const ogImageAlt = 'Clawdemy: From zero to autonomous, one lesson at a time.';
---

<Default><slot /></Default>

<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={ogImageAlt} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={ogImageAlt} />
